--==================================================
-- Boot / Cleanup
--==================================================

do
    local Old = getgenv()[SCRIPT_ID]

    if Old then
        if Old.Library and not Old.Library.Unloaded then
            pcall(function()
                Old.Library:Unload()
            end)
        end

        if Old.Connections then
            for _, Connection in ipairs(Old.Connections) do
                pcall(function()
                    Connection:Disconnect()
                end)
            end
        end
    end

    local CoreGui = game:GetService("CoreGui")

    for _, Gui in ipairs(CoreGui:GetChildren()) do
        if Gui:IsA("ScreenGui") then
            local Name = Gui.Name:lower()

            if Name:find("obsidian") or Name:find("linoria") or Name:find("pollutedbaseui") then
                pcall(function()
                    Gui:Destroy()
                end)
            end
        end
    end

    getgenv()[SCRIPT_ID] = {
        Connections = {},
        Alive = true,
        Functions = {},
    }
end

