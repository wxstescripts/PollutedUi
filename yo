local function WaitForKickStart()
    local Start = tick()

    while tick() - Start < State.AutoKickTimeout do
        if not State.AutoKick and not State.FarmBusy then
            return false
        end

        if Modules.KickController and Modules.KickController.InMinigame == true then
            return true
        end

        local RunGui = FindRunGui()

        if RunGui and IsGuiReallyVisible(RunGui) then
            return true
        end

        task.wait(0.05)
    end

    return false
end

local function WaitForKickEnd()
    local Start = tick()

    while tick() - Start < State.AutoKickTimeout do
        if not State.AutoKick and not State.FarmBusy then
            return false
        end

        if Modules.KickController and Modules.KickController.InMinigame == false then
            return true
        end

        task.wait(0.05)
    end

    return true
end

