local function SetLabel(Label, Text)
    if not Label then return end

    if Label.SetText then
        pcall(function()
            Label:SetText(Text)
        end)
    elseif Label.Set then
        pcall(function()
            Label:Set(Text)
        end)
    elseif Label.Text ~= nil then
        pcall(function()
            Label.Text = Text
        end)
    end
end

