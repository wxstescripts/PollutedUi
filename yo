    local Keys = {}

    if type(Table) ~= "table" then
        return Keys
    end

    for Key, _ in pairs(Table) do
        table.insert(Keys, tostring(Key))
    end

    table.sort(Keys)
    return Keys
end

local function ReadEventState()
    local Active = {}
    local WeatherServiceClient = Modules.WeatherServiceClient

    if WeatherServiceClient then
        if type(WeatherServiceClient.Events) == "table" then
            local EventKeys = GetTableKeys(WeatherServiceClient.Events)

            if #EventKeys > 0 then
                table.insert(Active, "Events: " .. table.concat(EventKeys, ", "))
            end
        end

        for _, Key in ipairs({
            "CurrentWeather",
            "Weather",
            "CurrentEvent",
            "Event",
            "ActiveWeather",
            "ActiveEvent",
        }) do
            local Value = WeatherServiceClient[Key]

            if Value ~= nil then
                table.insert(Active, Key .. ": " .. tostring(Value))
            end
        end
    end

    if #Active == 0 then
        table.insert(Active, "No active weather found")
    end

    return table.concat(Active, "\n")
end

local function ReadServerLuck()
    local ServerLuckClient = Modules.ServerLuckClient

    if not ServerLuckClient then
        return "Server luck module not loaded"
    end

    local Lines = {}

    for _, Key in ipairs({
        "Multiplier",
        "CurrentMultiplier",
        "Luck",
        "ServerLuck",
        "EndTime",
        "TimeLeft",
    }) do
        local Value = ServerLuckClient[Key]

        if Value ~= nil then
            table.insert(Lines, Key .. ": " .. tostring(Value))
        end
    end

    if #Lines == 0 then
        return "No server luck data found"
    end

    return table.concat(Lines, "\n")
end

local function ReadTimedBoosts()
    local TimedUpgradesServiceClient = Modules.TimedUpgradesServiceClient

    if not TimedUpgradesServiceClient then
        return "Timed upgrades module not loaded"
    end

    local Lines = {}

    for _, Key in ipairs({
        "Multipliers",
        "EndTimes",
        "ActiveBoosts",
        "Boosts",
        "Timers",
    }) do
        local Value = TimedUpgradesServiceClient[Key]

        if type(Value) == "table" then
            local Keys = GetTableKeys(Value)

            if #Keys > 0 then
                table.insert(Lines, Key .. ": " .. table.concat(Keys, ", "))
            end
        elseif Value ~= nil then
            table.insert(Lines, Key .. ": " .. tostring(Value))
        end
    end

    if #Lines == 0 then
        return "No timed boost data found"
    end

    return table.concat(Lines, "\n")
end

