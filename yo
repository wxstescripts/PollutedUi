-- Farm Controller
--==================================================

local function SetFarmStatus(Text)
    SetLabel(Labels.FarmStatus, "Farm: " .. Text)
end

local function SetFarmStep(Text)
    SetLabel(Labels.FarmStep, "Current Step: " .. Text)
end

local function AnyFarmEnabled()
    return State.AutoSquat
        or State.AutoBonus
        or State.AutoCollect
        or State.AutoKick
        or State.AutoPlotUpgrade
        or State.AutoRebirth
        or State.AutoSlotUpgrade
end

local function StartFarmController()
    if State.FarmRunning then return end

    State.FarmRunning = true
    SetFarmStatus("running")

    task.spawn(function()
        while State.FarmRunning and not Library.Unloaded do
            if not AnyFarmEnabled() then
                SetFarmStatus("idle")
                State.FarmRunning = false
                break
            end

            if not State.FarmBusy then
                State.FarmBusy = true

                local Now = tick()

                if State.AutoSquat and not State.AutoKick and not State.FarmBusy then
									    SetFarmStep("Auto Squat")
									
									    KeepSquatEquipped()
									    KeepSquatMovementUnlocked()
									end

                if State.AutoBonus and Now - State.LastBonus >= State.AutoBonusDelay then
                    SetFarmStep("Bonus Farm")
                    State.LastBonus = Now
                    ClickBonusButton()
                end

                if State.AutoKick and Now - State.LastKick >= State.AutoKickDelay then
                    SetFarmStep("Auto Kick")
                    State.LastKick = Now
                    RunKickCycle()
                end

                if State.AutoCollect and Now - State.LastCollect >= State.AutoCollectInterval then
                    SetFarmStep("Auto Collect")
                    State.LastCollect = Now
                    CollectAllButtons()
                end

                if State.AutoPlotUpgrade and Now - State.LastPlotUpgrade >= State.PlotUpgradeDelay then
                    SetFarmStep("Plot Upgrade")
                    State.LastPlotUpgrade = Now
                    FirePlotUpgrade()
                end

                if State.AutoRebirth and Now - State.LastRebirth >= State.RebirthDelay then
                    SetFarmStep("Rebirth")
                    State.LastRebirth = Now
                    FireRebirth()
                end

                if State.AutoSlotUpgrade and Now - State.LastSlotUpgrade >= State.SlotUpgradeDelay then
                    local SlotNumber = GetSelectedUpgradeSlot()

                    if SlotNumber then
                        SetFarmStep("Slot Upgrade")
                        State.LastSlotUpgrade = Now
                        UpgradeBrainrotSlot(SlotNumber)
                    end
                end

                State.FarmBusy = false
            end

            task.wait(0.1)
        end

        State.FarmRunning = false
        State.FarmBusy = false
        SetFarmStep("none")
    end)
end

local function StopAllFarmFeatures()
    State.AutoSquat = false
    State.AutoBonus = false
    State.AutoCollect = false
    State.AutoKick = false
    State.AutoPlotUpgrade = false
    State.AutoRebirth = false
    State.AutoSlotUpgrade = false
    State.FarmRunning = false
    State.FarmBusy = false

    UnequipTools()
    SetFarmStatus("stopped")
    SetFarmStep("none")
end

