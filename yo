function PH.Cleanup()
    PH.Alive = false

    pcall(function()
        StopAllFarmFeatures()
    end)

    for _, Connection in ipairs(PH.Connections) do
        pcall(function()
            Connection:Disconnect()
        end)
    end

    pcall(function()
        Library:Unload()
    end)
end

