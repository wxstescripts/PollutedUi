    if not SlotsFolder then
        table.insert(Brainrots, "No Brainrots Found")
        SetLabel(Labels.BrainrotCount, "Brainrots Found: 0")
        return Brainrots
    end

    for _, Slot in ipairs(SlotsFolder:GetChildren()) do
        local SlotNumber = tonumber(Slot.Name:match("%d+"))
        local PlacedPart = Slot:FindFirstChild("PlacedPart")

        if SlotNumber and PlacedPart then
            local BrainrotModel = nil

            for _, Child in ipairs(PlacedPart:GetChildren()) do
                BrainrotModel = Child
                break
            end

            if BrainrotModel then
                local DisplayName = "Slot "
                    .. tostring(SlotNumber)
                    .. " | "
                    .. GetBrainrotMutation(BrainrotModel)
                    .. " | "
                    .. BrainrotModel.Name

                table.insert(Brainrots, DisplayName)
                State.BrainrotSlotMap[DisplayName] = SlotNumber
            end
        end
    end

    table.sort(Brainrots, function(a, b)
        local SlotA = tonumber(a:match("Slot%s+(%d+)")) or 0
        local SlotB = tonumber(b:match("Slot%s+(%d+)")) or 0

        if SlotA == SlotB then
            return a < b
        end

        return SlotA < SlotB
    end)

    SetLabel(Labels.BrainrotCount, "Brainrots Found: " .. tostring(#Brainrots))

    if #Brainrots == 0 then
        table.insert(Brainrots, "No Brainrots Found")
    end

    return Brainrots
