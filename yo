end

local function RunKickCycle()
    local KickReadyPart = GetKickReadyPart()
		SaveCurrentBackpackBrainrots()

    if not KickReadyPart then
        SetKickStatus("KickReady not found")
        return false
    end

    if State.TeleportBeforeKick then
        SetKickStatus("teleporting to KickReady")

        if not TeleportToKickReady() then
            SetKickStatus("failed to teleport")
            return false
        end

        task.wait(0.5)
    end

    SetKickStatus("kicking")
    SetKickPowerPercent(State.KickPowerPercent)
    FireKickEvent()

    SetKickStatus("waiting for kick minigame")

    if not WaitForKickStart() then
        SetKickStatus("Run UI timeout")
        return false
    end

    SetKickStatus("kick detected")
    WaitForKickEnd()
    task.wait(State.AutoKickPostDelay)

    SetKickStatus("returning to KickReady")

    if not MoveBackTo(KickReadyPart.Position) then
        SetKickStatus("return failed")
        return false
    end

    task.wait(2)
    PlaceOrStoreBrainrot()
		SendNewBackpackBrainrots()

    return true
end

