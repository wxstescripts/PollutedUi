    Title.TextXAlignment = Enum.TextXAlignment.Left
    Title.TextTruncate = Enum.TextTruncate.AtEnd
    Title.Parent = TopBar

    local function MakeButton(Text, X)
        local Button = Instance.new("TextButton")
        Button.Size = UDim2.fromOffset(30, 30)
        Button.Position = UDim2.new(1, X, 0.5, -15)
        Button.BackgroundColor3 = Color3.fromRGB(28, 30, 42)
        Button.Text = Text
        Button.Font = Enum.Font.GothamBold
        Button.TextColor3 = Color3.fromRGB(255, 255, 255)
        Button.TextSize = 18
        Button.Parent = TopBar

        local ButtonCorner = Instance.new("UICorner")
        ButtonCorner.CornerRadius = UDim.new(1, 0)
        ButtonCorner.Parent = Button

        return Button
    end

    local ZoomOut = MakeButton("-", -110)
    local ZoomIn = MakeButton("+", -74)
    local Close = MakeButton("×", -38)

    local Viewport = Instance.new("ViewportFrame")
    Viewport.Size = UDim2.new(1, -16, 1, -58)
    Viewport.Position = UDim2.new(0, 8, 0, 50)
    Viewport.BackgroundColor3 = Color3.fromRGB(6, 6, 10)
    Viewport.BackgroundTransparency = 0.05
    Viewport.Ambient = Color3.fromRGB(230, 230, 230)
    Viewport.LightColor = Color3.fromRGB(255, 255, 255)
    Viewport.LightDirection = Vector3.new(-1, -1, -1)
    Viewport.Parent = Frame

    local ViewCorner = Instance.new("UICorner")
    ViewCorner.CornerRadius = UDim.new(0, 14)
    ViewCorner.Parent = Viewport

    local Camera = Instance.new("Camera")
    Camera.Parent = Viewport
    Viewport.CurrentCamera = Camera

    local Clone = Entity:Clone()
    Clone.Parent = Viewport

    local CF, Size = Clone:GetBoundingBox()
    local MaxSize = math.max(Size.X, Size.Y, Size.Z)

    Clone:PivotTo(CFrame.new(0, 0, 0))

    local Zoom = 2.25
    local Rotating = true

    local function UpdateCamera()
        Camera.CFrame = CFrame.new(
            Vector3.new(0, MaxSize * 0.22, MaxSize * Zoom),
            Vector3.new(0, MaxSize * 0.12, 0)
        )
    end

    UpdateCamera()

    ZoomIn.MouseButton1Click:Connect(function()
        Zoom = math.max(1.25, Zoom - 0.2)
        UpdateCamera()
    end)

    ZoomOut.MouseButton1Click:Connect(function()
        Zoom = math.min(4, Zoom + 0.2)
        UpdateCamera()
    end)

    local RotationConnection
    RotationConnection = RunService.RenderStepped:Connect(function()
        if not Gui.Parent or not Clone.Parent then
            if RotationConnection then RotationConnection:Disconnect() end
            return
        end

        if Rotating then
            Clone:PivotTo(Clone:GetPivot() * CFrame.Angles(0, math.rad(0.65), 0))
        end
    end)

    Viewport.InputBegan:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.Touch or Input.UserInputType == Enum.UserInputType.MouseButton1 then
            Rotating = not Rotating
        end
    end)

    Close.MouseButton1Click:Connect(function()
        if RotationConnection then RotationConnection:Disconnect() end
        Gui:Destroy()
    end)

    return Gui
end

local function TryCaptureEntityPreview(EntityName)
    if PreviewUploadCache[EntityName] then
        return PreviewUploadCache[EntityName]
    end

    local ScreenshotFunction = GetScreenshotFunction()

    if not ScreenshotFunction then
        return nil
    end

    local Gui = CreateEntityPreviewGui(EntityName)

    if not Gui then
        return nil
    end

    task.wait(0.85)

    local Success, Screenshot = pcall(function()
        return ScreenshotFunction()
    end)

    pcall(function()
        Gui:Destroy()
    end)

    if not Success or not Screenshot or Screenshot == "" then
        return nil
    end

    PreviewUploadCache[EntityName] = Screenshot
    return Screenshot
end

local function SendBrainrotWebhook(BrainrotName, ExtraText)
    if State.WebhookURL == "" then
        Library:Notify({
            Title = "Webhook",
            Description = "Set your webhook URL first.",
            Time = 3,
        })
        return false
    end

    local Request = GetRequestFunction()

    if not Request then
        Library:Notify({
            Title = "Webhook",
            Description = "Your executor does not support HTTP requests.",
            Time = 3,
        })
        return false
    end

    local Image =
        TryCaptureEntityPreview(BrainrotName)
        or GetEntityImage(BrainrotName)

    print("Webhook Brainrot:", BrainrotName)
    print("Webhook Image:", Image or "NO IMAGE FOUND")

    local Embed = {
        title = "🧠 Brainrot Found",
        description = ExtraText or "A new brainrot was detected and added to inventory.",
        color = 5763719,

        fields = {
            {
                name = "🎯 Brainrot",
                value = "```" .. tostring(BrainrotName) .. "```",
                inline = true,
            },
            {
                name = "👤 Player",
