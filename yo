local function BuildKeyTab()
    if not Tabs.Key then
        return
    end

    Tabs.Key:AddLabel({
        Text = "Developer and tester access only.",
        DoesWrap = true,
        Size = 16,
    })

    Tabs.Key:AddKeyBox(function(ReceivedKey)
        if ReceivedKey == Config.DevKey then
            if not IsDevUser() then
                Library:Notify({
                    Title = "Access Denied",
                    Description = "Your UserId is not whitelisted for developer access.",
                    Time = 5,
                })

                return
            end

            LoadDevTab()
            LoadTestingTab()

            Library:Notify({
                Title = "Dev Access Granted",
                Description = "Developer and testing tabs have been loaded.",
                Time = 5,
            })

            return
        end

        if ReceivedKey == Config.TesterKey then
            if not IsTesterUser() then
                Library:Notify({
                    Title = "Access Denied",
                    Description = "Your UserId is not whitelisted for tester access.",
                    Time = 5,
                })

                return
            end

            LoadTestingTab()

            Library:Notify({
                Title = "Tester Access Granted",
                Description = "Testing tab has been loaded.",
                Time = 5,
            })

            return
        end

        Library:Notify({
            Title = "Invalid Key",
            Description = "The key you entered is incorrect.",
            Time = 5,
        })
    end)
end

