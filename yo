local function FireRemote(Name, ...)
    local Args = { ... }

    if NetworkModule and NetworkModule.FireServer then
        local ok = pcall(function()
            NetworkModule.FireServer(Name, unpack(Args))
        end)

        if ok then
            return true
        end
    end

    local Remote = NetworkFolder:FindFirstChild("rev_" .. Name)

    if not Remote then
        Remote = NetworkFolder:WaitForChild("rev_" .. Name, 5)
    end

    if Remote then
        return pcall(function()
            Remote:FireServer(unpack(Args))
        end)
    end

    return false
end

local function InvokeRemote(Name, ...)
    local Args = { ... }

    if NetworkModule and NetworkModule.InvokeServer then
        local ok, result = pcall(function()
            return NetworkModule.InvokeServer(Name, unpack(Args))
        end)

        if ok then
            return true, result
        end
    end

    local Remote = NetworkFolder:FindFirstChild("ref_" .. Name)

    if not Remote then
        Remote = NetworkFolder:WaitForChild("ref_" .. Name, 5)
    end

    if Remote then
        return pcall(function()
            return Remote:InvokeServer(unpack(Args))
        end)
    end

    return false, nil
end

