local function NormalizeName(Name)
    return tostring(Name or "")
        :lower()
        :gsub("%s+", "")
        :gsub("%p+", "")
end

local function FindToolByName(ToolName)
    local Character = LocalPlayer.Character
    local Backpack = LocalPlayer:FindFirstChildOfClass("Backpack")

    local Wanted = NormalizeName(ToolName)

    local function Scan(Container)
        if not Container then
            return nil
        end

        local ExactTool = Container:FindFirstChild(ToolName)

        if ExactTool and ExactTool:IsA("Tool") then
            return ExactTool
        end

        for _, Item in ipairs(Container:GetChildren()) do
            if Item:IsA("Tool") then
                local ItemName = NormalizeName(Item.Name)

                if ItemName == Wanted then
                    return Item
                end
            end
        end

        for _, Item in ipairs(Container:GetChildren()) do
            if Item:IsA("Tool") then
                local ItemName = NormalizeName(Item.Name)

                if ItemName:find(Wanted, 1, true) or Wanted:find(ItemName, 1, true) then
                    return Item
                end
            end
        end

        return nil
    end

    return Scan(Character) or Scan(Backpack)
end

