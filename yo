                inline = false,
            },
        },

        footer = {
            text = "Polluted Hub • Brainrot Logger",
        },

        timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
    }

    if Image and tostring(Image):find("^https?://") then
        Embed.thumbnail = {
            url = Image,
        }
    end

    local Payload = {
        username = "Polluted Hub",
        avatar_url = "https://i.imgur.com/8wmK8SE.png",
