            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json",
            },
            Body = HttpService:JSONEncode(Payload),
        })
    end)

    return Success
end

local function GetBackpackBrainrots()
    local Backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
    local Found = {}

    if not Backpack then
        return Found
    end

    local EntityFolder = GetEntityFolder()

    if not EntityFolder then
        return Found
    end

    for _, Tool in ipairs(Backpack:GetChildren()) do
        if Tool:IsA("Tool") and EntityFolder:FindFirstChild(Tool.Name) then
            Found[Tool.Name] = true
        end
    end

    return Found
end

local function SaveCurrentBackpackBrainrots()
    State.KnownBackpackBrainrots = GetBackpackBrainrots()
end

local function SendNewBackpackBrainrots()
    State.KnownBackpackBrainrots = State.KnownBackpackBrainrots or {}

    local Current = GetBackpackBrainrots()

    for BrainrotName, _ in pairs(Current) do
        if not State.KnownBackpackBrainrots[BrainrotName] then
            local LastSent = State.LastWebhookSent[BrainrotName] or 0

            if tick() - LastSent >= State.WebhookCooldown then
                State.LastWebhookSent[BrainrotName] = tick()

                SendBrainrotWebhook(
                    BrainrotName,
                    "New brainrot added to backpack after a successful kick."
                )
            end
        end
    end

    State.KnownBackpackBrainrots = Current
end

