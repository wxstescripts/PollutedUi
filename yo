local function GetEntityFolder()
    return ReplicatedStorage:FindFirstChild("Objects")
        and ReplicatedStorage.Objects:FindFirstChild("Entities")
end

local function GetEntityNames()
    local Folder = GetEntityFolder()
    local Names = {}

    if Folder then
        for _, Entity in ipairs(Folder:GetChildren()) do
            table.insert(Names, Entity.Name)
        end
    end

    table.sort(Names)

    if #Names == 0 then
        table.insert(Names, "No Entities Found")
    end

    return Names
end

local function ExtractAssetId(Value)
    if not Value or Value == "" then
        return nil
    end

    return tostring(Value):match("rbxassetid://(%d+)")
        or tostring(Value):match("id=(%d+)")
        or tostring(Value):match("assetId=(%d+)")
        or tostring(Value):match("(%d+)")
end

local function NormalizeAsset(Id)
    local AssetId = ExtractAssetId(Id)

    if not AssetId then
        return nil
    end

    local Request = GetRequestFunction()

    if not Request then
        return nil
    end

    local Url =
        "https://thumbnails.roblox.com/v1/assets"
        .. "?assetIds=" .. AssetId
        .. "&size=420x420"
        .. "&format=Png"
        .. "&isCircular=false"

    local Success, Response = pcall(function()
        return Request({
            Url = Url,
            Method = "GET",
        })
    end)

    if not Success or not Response or not Response.Body then
        return nil
    end

    local Data

    pcall(function()
        Data = HttpService:JSONDecode(Response.Body)
    end)

    local Image =
        Data
        and Data.data
        and Data.data[1]
        and Data.data[1].imageUrl

    if not Image or Image == "" then
        return nil
    end

    Image = tostring(Image)

    local LowerImage = string.lower(Image)

    if LowerImage:find("placeholder")
        or LowerImage:find("default")
        or LowerImage:find("nofilter")
        or LowerImage:find("404")
        or LowerImage:find("error")
    then
        return nil
    end

    return Image
end

local function GetEntityImage(EntityName)
    if EntityImageCache[EntityName] then
        return EntityImageCache[EntityName]
    end

    local Folder = GetEntityFolder()
    local Entity = Folder and Folder:FindFirstChild(EntityName)

    if not Entity then
        return nil
    end

    local function TryAsset(Value)
        local Image = NormalizeAsset(Value)

        if Image then
            EntityImageCache[EntityName] = Image
            return Image
        end

        return nil
    end

    -- Best texture source
    for _, Item in ipairs(Entity:GetDescendants()) do
        if Item:IsA("SurfaceAppearance") then
            if Item.ColorMap and Item.ColorMap ~= "" then
                local Image = TryAsset(Item.ColorMap)
                if Image then return Image end
            end
        end
    end

    -- UI/image objects
    for _, Item in ipairs(Entity:GetDescendants()) do
        if Item:IsA("Decal") or Item:IsA("Texture") then
            if Item.Texture and Item.Texture ~= "" then
                local Image = TryAsset(Item.Texture)
                if Image then return Image end
            end
        end

        if Item:IsA("ImageLabel") or Item:IsA("ImageButton") then
            if Item.Image and Item.Image ~= "" then
                local Image = TryAsset(Item.Image)
                if Image then return Image end
            end
        end
    end

    -- Mesh texture fallback
    for _, Item in ipairs(Entity:GetDescendants()) do
        if Item:IsA("MeshPart") then
            if Item.TextureID and Item.TextureID ~= "" then
                local Image = TryAsset(Item.TextureID)
                if Image then return Image end
            end
        end

        if Item:IsA("SpecialMesh") then
            if Item.TextureId and Item.TextureId ~= "" then
                local Image = TryAsset(Item.TextureId)
                if Image then return Image end
            end
        end
    end

    return nil
end

